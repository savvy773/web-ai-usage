# Shared working directories for Claude, Codex, and Gemini CLI.
# Authenticate/trust each CLI once in the preferred directory.
# When these values are set, only these shared candidates are used.
# Values may use %TEMP%, %TMP%, $env:TEMP, $env:TMP, or paths relative to this project.
AI_USAGE_CWD=..\..\_temp
AI_USAGE_CWD_CANDIDATES=%TEMP%

# Leave unset unless testing the bundled node-pty ConPTY DLL on Windows.
# AI_USAGE_USE_CONPTY_DLL=1
