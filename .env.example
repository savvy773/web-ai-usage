# Preferred working directory where CLIs are launched.
# Add fallback directories with semicolons. The collector also tries %USERPROFILE% and the install path.
# Each target CLI must be authenticated/trusted in at least one candidate directory.
# AI_USAGE_CWD=C:\Users\yourname\some-dir
# AI_USAGE_CWD_CANDIDATES=D:\Code\_temp;C:\Users\yourname;D:\Code\_toolkit\aI_usage
